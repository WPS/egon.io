{
  "name": "egon",
  "version": "4.0.0-dev",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "test": "jest",
    "coverage": "jest --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run format:check && npm run typecheck && npm run archlint && npm run test",
    "build": "ng build",
    "build-prod": "ng build --configuration production",
    "zip": "zip-build dist_build/ dist/ --template '%NAME%-%VERSION%.%EXT%'",
    "archlint": "node ./node_modules/ts-archlint/dist/index.js ./src/app"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.13",
    "@angular/cdk": "^21.2.13",
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/material": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/platform-browser-dynamic": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@bpmn-io/align-to-origin": "0.7.0",
    "bpmn-font": "^0.12.1",
    "diagram-js": "^15.4.0",
    "diagram-js-direct-editing": "^3.2.0",
    "diagram-js-minimap": "^5.2.0",
    "dot": "^1.1.3",
    "ids": "^1.0.5",
    "inherits-browser": "^0.1.0",
    "material-icons": "^1.13.14",
    "min-dash": "^4.2.3",
    "ngx-color-picker": "^20.1.1",
    "rxjs": "^7.4.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "jest": "^30.4.2",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^17.0.0",
    "ng-mocks": "^14.14.0",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "prettier": "^3.7.3",
    "ts-archlint": "^0.23.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zip-build": "^1.8.0"
  }
}
